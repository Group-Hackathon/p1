# Global App Backend - Environment Variables
# Copy this file to .env and fill in real values

# Database
DATABASE_URL=postgres://patient:secure_password@localhost:5432/living_patient_memory?sslmode=disable

# JWT Secret (change this in production!)
JWT_SECRET=dev-secret-change-in-production

# Server
PORT=8080

# Gemini API (AI Studio) - primary backend, latest flash models.
# NEVER commit the real key. In production it comes from GCP Secret Manager.
GEMINI_API_KEY=your-ai-studio-api-key-here
GEMINI_MODEL=gemini-3.5-flash

# Vertex AI - automatic fallback if the API key is missing/out of credits
GCP_PROJECT_ID=living-patient-memory
GCP_LOCATION=us-central1
VERTEX_FALLBACK_MODEL=gemini-2.5-flash
